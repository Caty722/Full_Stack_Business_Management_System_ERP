.modern-invoice-container {
    width: 210mm;
    min-height: 297mm;
    margin: 0 auto;
    background: #fff !important;
    color: #000 !important;
    padding: 15mm;
    box-sizing: border-box;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    position: relative;
}

.modern-header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 8mm;
}

.modern-invoice-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.modern-recipient-type {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #444 !important;
}

.modern-shop-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10mm;
}

.modern-shop-info {
    max-width: 60%;
}

.modern-shop-name {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 2mm;
    color: #000 !important;
}

.modern-shop-details {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #333 !important;
}

.modern-logo-container img {
    max-width: 120px;
    height: auto;
}

.modern-info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5mm;
    margin-bottom: 8mm;
}

.modern-info-col {
    display: flex;
    flex-direction: column;
}

.modern-info-label {
    font-size: 0.85rem;
