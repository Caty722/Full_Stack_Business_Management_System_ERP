    grid-template-columns: repeat(3, 1fr);
    gap: 8mm;
    margin-bottom: 12mm;
}

.modern-address-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: #555 !important;
    margin-bottom: 2mm;
