/* ==========================================================================
   EMERGENCY RECONSTRUCTION: MODAL & DARK MODE FIXES
   ========================================================================== */

.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
}

.modal-content {
    background: var(--bg-surface);
    border-radius: 20px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    border: 1px solid var(--border-color);
}

/* Force dark text on white invoice background regardless of theme */
.invoice-document,
.gst-invoice-container,
.modern-invoice-container {
    background: #fff !important;
    color: #000 !important;
}

.dark .invoice-document *,
.dark .gst-invoice-container *,
.dark .modern-invoice-container * {
    color: #000 !important;
}

/* Fix for large Lucide icons in stats */
.stat-icon svg {
    width: 24px !important;
    height: 24px !important;
}

.action-btn {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    background: rgba(0, 0, 0, 0.04);
}

.dark .action-btn {
    background: rgba(255, 255, 255, 0.06);
}

.action-btn:hover {
    background: rgba(99, 102, 241, 0.1);
    color: #6366f1;
    transform: translateY(-1px);
}
